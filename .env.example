# ============================================================
# AdCommand — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Supabase — found at https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anthropic API key — stored as a Supabase Edge Function secret, NOT here
# Run: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# The frontend never sees this key directly

# Optional — Meta Ads API (for live data sync)
# VITE_META_APP_ID=your_meta_app_id
# META_APP_SECRET=your_meta_app_secret  (server-side only)

# Optional — Shopify (for live revenue sync)
# SHOPIFY_API_KEY=your_shopify_api_key  (server-side only)
